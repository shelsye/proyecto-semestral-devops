# =====================================================================
# Plantilla de variables de entorno.
# Copia este archivo a ".env" y ajusta los valores.
# IMPORTANTE: ".env" está en .gitignore, NUNCA subas credenciales reales.
# =====================================================================

# Región de AWS donde está el clúster y los repos de ECR
AWS_REGION=us-east-1

# Tag de las imágenes a desplegar (en CI/CD se usa el SHA del commit)
IMAGE_TAG=latest

# Contraseña root de MySQL (se inyecta en el Secret de Kubernetes)
MYSQL_ROOT_PASSWORD=admin123

# Nombre del clúster EKS (debe coincidir con infra/eksctl-cluster.yaml)
EKS_CLUSTER_NAME=innovatech-eks
